    {
      "id": "features",
      "number": "04",
      "nav": "Features",
      "eyebrow": "Features (MoSCoW)",
      "title": "Was bauen wir wann?",
      "blocks": [
        {
          "moscow": [
            {
              "quadrant": "must",
              "title": "Must Have · MVP",
              "items": [
                "Registrierung & Login (E-Mail, Social)",
                "Spieleübersicht mit Status (offen/geschlossen)",
                "Bewertungs-UI: 5 Kriterien, Skala 0–10, Pflichtfelder",
                "Eine Bewertung pro Spiel & User (One-Vote)",
                "Live Radar Chart (eigene vs. Durchschnitt)",
                "Ranking & Leaderboard nach Bewertungsende",
                "Badges für Top-Bewerter",
                "Manipulationsschutz & Account-Checks",
                "Onboarding, Tooltips, FAQ"
              ]
            },
            {
              "quadrant": "should",
              "title": "Should Have · Release 1.1",
              "items": [
                "Push-/E-Mail-Erinnerungen vor Spielende",
                "Sponsoren-Branding & Preisintegration",
                "Badges für regelmäßige Teilnahme",
                "Admin-Panel für Spielverwaltung",
                "Historische Statistiken & Filter",
                "Progressive Web App (PWA)"
              ]
            },
            {
              "quadrant": "could",
              "title": "Could Have · Phase 2+",
              "items": [
                "Community-Gruppen & Fan-Channels",
                "Social Sharing für eigene Platzierung",
                "Premium-Features & Analytics",
                "Vereins-API-Integration",
                "Mehrsprachigkeit (i18n)",
                "Trainer-/Spielerbewertung (bilateral)"
              ]
            },
            {
              "quadrant": "wont",
              "title": "Won't Have · MVP ausgeschlossen",
              "items": [
                "Freie Kriterienwahl durch User",
                "Live-Tracking externer Statistiken",
                "Internes Messaging / Chat",
                "Automatisierte Preisauszahlung",
                "White-Label-Plattform"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "scope",
      "number": "05",
      "nav": "Scope",
      "eyebrow": "Scope & Abgrenzung",
      "title": "Was ist TEAMCHEF nicht?",
      "blocks": [
        {
          "columns": 2,
          "cards": [
            {
              "title": "✓ Im Scope (MVP)",
              "titleTone": "green",
              "list": [
                "Bewertungsplattform für Fußballspiele & Teams",
                "Community-Ranking auf Basis von Schwarmintelligenz",
                "Gamification: Punkte, Badges, Preise",
                "Echtzeit-Visualisierung (Radar Chart)",
                "Grundlegendes Anti-Manipulation-System",
                "Web-App (mobil-optimiert, keine native App)"
              ]
            },
            {
              "title": "✗ Außerhalb Scope (MVP)",
              "titleTone": "red",
              "list": [
                "Kein Live-Spielscore-Tracking",
                "Keine Trainer- oder Spieler-spezifischen Accounts",
                "Keine freien Kommentarfelder oder Freitext",
                "Keine externe Vereins-/Ligadaten-Integration",
                "Kein Video-Content oder Stream-Anbindung",
                "Keine Zahlungsabwicklung im MVP"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "akzeptanz",
      "number": "06",
      "nav": "Akzeptanz",
      "eyebrow": "Akzeptanzkriterien",
      "title": "Wann ist das Produkt „fertig\"?",
      "blocks": [
        {
          "acceptance": {
            "items": [
              {
                "number": "1",
                "title": "Bewertungszeitraum",
                "body": "Bewertungen sind nur während des aktiven Spiels und bis max. 1 Stunde nach Spielende möglich. Das System zeigt klar an, ob Bewertung offen oder geschlossen ist."
              },
              {
                "number": "2",
                "title": "One-Vote-Logik",
                "body": "Pro Spiel kann jeder Nutzer genau eine vollständige Bewertung abgeben. Alle 5 Kriterien müssen ausgefüllt sein. Wiederholung ist technisch gesperrt."
              },
              {
                "number": "3",
                "title": "Echtzeit-Feedback",
                "body": "Während der Eingabe aktualisiert sich der Radar Chart sofort. Der Nutzer sieht live seine Werte und den aktuellen Durchschnitt aller bisherigen Bewertungen."
              },
              {
                "number": "4",
                "title": "Ranking & Gamification",
                "body": "Nach Bewertungsende wird das Ranking automatisch berechnet und veröffentlicht. Preise und Badges werden korrekt vergeben und im UI angezeigt."
              },
              {
                "number": "5",
                "title": "Manipulationsschutz",
                "body": "Jede User-ID kann pro Spiel nur einmal bewerten. Für ein offizielles Ranking sind mindestens 30 Bewertungen erforderlich. Auffällige Muster werden erkannt und markiert."
              },
              {
                "number": "6",
                "title": "Zugänglichkeit & Support",
                "body": "Tooltips, FAQ und Kontaktformular sind jederzeit erreichbar. Das UI ist barrierefrei gestaltet (WCAG AA), vollständig mobil-optimiert und in unter 1 Minute erlernbar."
              }
            ]
          }
        }
      ]
    },
