      "id": "trends",
      "number": "04",
      "nav": "Trends",
      "eyebrow": "Markttrends",
      "title": "Warum jetzt der richtige Zeitpunkt ist",
      "blocks": [
        {
          "trends": [
            {
              "icon": "📈",
              "title": "Fan-Partizipation wächst",
              "body": "Passive Zuschauer werden aktive Teilnehmer. Twitch, Discord, Fan-Token (Socios) zeigen: Fans wollen mitbestimmen. TEAMCHEF nutzt das für strukturierte Beteiligung."
            },
            {
              "icon": "🎮",
              "title": "Gamification ist Standard",
              "body": "Duolingo, Strava, Wordle – Punkte, Streaks, Badges sind keine Innovation mehr, sondern Erwartung. Sport-Apps ohne Gamification verlieren Engagement."
            },
            {
              "icon": "🧠",
              "title": "Schwarmintelligenz als Datenmethode",
              "body": "Von Wikipedia über Prediction Markets bis Polymarket: Kollektive Einschätzungen sind oft genauer als Einzelurteile. TEAMCHEF wendet das auf Sport an."
            },
            {
              "icon": "💰",
              "title": "Sponsoring wird digital & messbar",
              "body": "Budgets verlagern sich von Bandenwerbung zu digitalen Kanälen mit messbarem ROI. Plattformen mit direktem Fan-Zugang sind die attraktivsten Partner."
            },
            {
              "icon": "📱",
              "title": "Mobile-First ist Pflicht",
              "body": "75%+ der Sport-Content-Nutzung auf dem Smartphone. Web-Apps (PWA) schließen den Gap zwischen App-Store-Hürde und nativer Experience."
            },
            {
              "icon": "⚡",
              "title": "Amateursport digitalisiert sich",
              "body": "Der Profi-Bereich ist übersättigt. Der Amateurbereich – 99% aller Vereine – ist digital unterversorgt. Hier startet TEAMCHEF: niedrige Konkurrenz, hohe Loyalität."
            }
          ]
        }
      ]
