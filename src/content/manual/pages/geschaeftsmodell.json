          "revenue": [
            {
              "title": "Sponsoring & Preisfinanzierung",
              "phase": {
                "label": "Phase 1",
                "tone": "green"
              },
              "description": "Unternehmen finanzieren die Gewinnspielpreise und erhalten dafür prominentes Branding\nim Bewertungsflow (z.B. „Gesponsert von [Firma]\" beim Loading Screen, im Ranking,\nauf der Bestätigungsseite). Direkte, messbare Reichweite zu einer hochaffinen Zielgruppe\nohne Streuverluste.",
              "mechanics": [
                "Sponsor stiftet Preis (Geld, Gutscheine, Sachpreise) für ein Spiel oder eine Saison",
                "Logo + Claim erscheint für alle Bewerter dieses Spiels sichtbar im UI",
                "Sponsor erhält Kampagnen-Reporting (Impressionen, Klicks, demografische Daten)",
                "Preisstruktur: Pauschalgebühr pro Spiel oder saisonales Paket"
              ]
            },
            {
              "title": "Native Advertising",
              "phase": {
                "label": "Phase 1",
                "tone": "green"
              },
              "description": "Werbeplatzierungen im Ranking-Bereich, im Onboarding und bei Spielbenachrichtigungen.\nThematisch zum Fußball passend (Sportwetten-Anbieter, Sportartikel, Energydrinks,\nlokale Unternehmen). Kein aggressives Ad-Format – native, kontextuell, respektvoll.",
              "mechanics": [
                "CPM- oder CPC-Abrechnung je nach Format",
                "Targeting nach Sportart, Region, Spieltermin",
                "Premium-Placement für Exklusiv-Sponsoren möglich"
              ]
            },
            {
              "title": "Premium-Abonnements",
              "phase": {
                "label": "Phase 2",
                "tone": "blue"
              },
              "description": "Nutzer, die tiefer in die Daten einsteigen wollen (z.B. Trainer, Vereinsverantwortliche,\nambitionierte Fans), können ein Premium-Abo abschließen. Dieses bietet erweiterte\nStatistiken, historische Bewertungsverläufe, personalisierte Insights und werbefreie Nutzung.",
              "mechanics": [
                "Monatliches oder jährliches Abo (Jahres-Rabatt als Anreiz)",
                "Werbefreiheit als Kern-Feature des Premium-Tiers",
                "Radar-Chart-Exporte, Team-Vergleiche, Saisonstatistiken",
                "Für Vereine: Team-Dashboard mit aggregierten Community-Bewertungen"
              ]
            },
            {
              "title": "Daten & Analytics B2B",
              "phase": {
                "label": "Phase 2",
                "tone": "blue"
              },
              "description": "Anonymisierte, aggregierte Bewertungsdaten sind für Vereine, Scouts und Medien\nhochwertig. Community-Einschätzungen über Spieler und Teams über Saisons hinweg\nergeben einzigartige Datensätze, die klassische Scouting-Methoden sinnvoll ergänzen.",
              "mechanics": [
                "API-Zugang für Vereine, Medien und Analyse-Unternehmen gegen Gebühr",
                "Custom Reports und Daten-Exports für Scouts & Journalisten",
                "Alle Daten vollständig anonymisiert und DSGVO-konform"
              ]
            },
            {
              "title": "White-Label & Lizenzierung",
              "phase": {
                "label": "Phase 3",
                "tone": "amber"
              },
              "description": "Verbände, Ligen und große Vereine können die TEAMCHEF-Plattform unter eigenem Branding\nbetreiben. Lizenzmodell ermöglicht Skalierung ohne eigene Entwicklungskosten beim Kunden.\nHochmargiger B2B-Revenue-Stream mit langfristiger Vertragsbindung.",
              "mechanics": [
                "Einmalige Setup-Gebühr + monatliche Lizenzgebühr",
                "Anpassbares Branding, eigene Kriterien, eigene Preisvergabe",
                "Technischer Support und SLA inklusive"
              ]
            }
          ]
        }
